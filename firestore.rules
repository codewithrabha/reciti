rules_version = '2';

// ReCiti Firestore security rules.
//
// Source of truth — version-controlled here. Apply by pasting into the
// Firebase console (Firestore Database → Rules → Publish), or deploy with the
// Firebase CLI: `firebase deploy --only firestore:rules`.

service cloud.firestore {
  match /databases/{database}/documents {

    // Signed in by any provider, including anonymous browsing sessions.
    function signedIn() {
      return request.auth != null;
    }

    // Signed in with a real account (not an anonymous session).
    function isRealUser() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ─── users ───────────────────────────────────────────────────────────
    // Profiles power the leaderboard and report attribution. They contain an
    // email, so reads require a session. A user may write their OWN profile,
    // or award civic points to ANOTHER user — but the award is capped to +10
    // per write and no other field may change. This second case backs the
    // "mark comment helpful" flow, which awards points to the comment author.
    match /users/{userId} {
      allow read:   if signedIn();
      allow create: if isRealUser() && request.auth.uid == userId;
      allow update: if isRealUser() && (
        request.auth.uid == userId
        || isPointAward()
      );
      allow delete: if false;

      function isPointAward() {
        let before = resource.data;
        let after  = request.resource.data;
        // Allow updates to completedDailyTrivia (stores trivia ID → ISO timestamp).
        // Client-side validation ensures only timestamps are stored.
        return after.uid == before.uid
            && after.displayName == before.displayName
            && after.email == before.email
            && after.photoURL == before.photoURL
            && after.completedDailyTrivia is map
            && after.civicPoints >= before.civicPoints
            && after.civicPoints <= before.civicPoints + 10;
      }
    }

    // ─── reports ─────────────────────────────────────────────────────────
    // Public to read. Only real accounts create reports, and a report must be
    // attributed to its creator. Updates are split into four mutually
    // exclusive operations — verify, flag, submit-fix, confirm-fix — each
    // tightly gated. A report may only be DELETED while it is an expired,
    // unverified pending report — this mirrors the client-side cleanup in
    // lib/db.ts, so nobody can delete arbitrary reports.
    match /reports/{reportId} {
      allow read:   if true;
      allow create: if isRealUser()
                       && request.resource.data.reporterId == request.auth.uid;
      allow update: if signedIn() && (
        isVerifyUpdate() ||
        isFlagUpdate() ||
        isSubmitResolution() ||
        isConfirmResolution()
      );
      allow delete: if signedIn()
                       && resource.data.status == 'pending'
                       && resource.data.verifiedBy.size() == 0
                       && request.time >
                            resource.data.createdAt + duration.value(1, 'h');

      // Fields that never change once a report is created. Every update
      // predicate composes this in. `imageUrls` is locked too, and the
      // equality handles old reports (missing the field) and new reports
      // (multi-photo array) the same way — only identical-or-both-absent
      // passes.
      function reportImmutables() {
        let before = resource.data;
        let after  = request.resource.data;
        return after.reportId    == before.reportId
            && after.reporterId  == before.reporterId
            && after.imageUrl    == before.imageUrl
            && after.imageUrls   == before.imageUrls
            && after.vibe        == before.vibe
            && after.category    == before.category
            && after.latitude    == before.latitude
            && after.longitude   == before.longitude
            && after.geohash     == before.geohash
            && after.createdAt   == before.createdAt
            && after.description == before.description;
      }

      // Verify: any signed-in user appends own uid to verifiedBy. At the
      // 3-verifier threshold the status flips pending → verified and
      // verifiedAt is set.
      function isVerifyUpdate() {
        let before = resource.data;
        let after  = request.resource.data;
        let nextVerified = before.verifiedBy.concat([request.auth.uid]);
        let flipping = nextVerified.size() >= 3 && before.status == 'pending';
        return reportImmutables()
            && before.status == 'pending'
            && !(request.auth.uid in before.verifiedBy)
            && after.verifiedBy == nextVerified
            && after.flaggedBy  == before.flaggedBy
            && (
                 (flipping && after.status == 'verified' && after.verifiedAt is timestamp)
                 || (!flipping && after.status == before.status && after.verifiedAt == before.verifiedAt)
               )
            && after.resolvedImageUrl       == before.resolvedImageUrl
            && after.resolvedBy             == before.resolvedBy
            && after.resolutionSubmittedAt  == before.resolutionSubmittedAt
            && after.resolutionConfirmedBy  == before.resolutionConfirmedBy
            && after.resolvedAt             == before.resolvedAt;
      }

      // Flag: any signed-in user appends own uid to flaggedBy. At 2 flags
      // the status flips to archived.
      function isFlagUpdate() {
        let before = resource.data;
        let after  = request.resource.data;
        let nextFlagged = before.flaggedBy.concat([request.auth.uid]);
        let flipping = nextFlagged.size() >= 2;
        return reportImmutables()
            && !(request.auth.uid in before.flaggedBy)
            && after.flaggedBy  == nextFlagged
            && after.verifiedBy == before.verifiedBy
            && (
                 (flipping && after.status == 'archived')
                 || (!flipping && after.status == before.status)
               )
            && after.verifiedAt             == before.verifiedAt
            && after.resolvedImageUrl       == before.resolvedImageUrl
            && after.resolvedBy             == before.resolvedBy
            && after.resolutionSubmittedAt  == before.resolutionSubmittedAt
            && after.resolutionConfirmedBy  == before.resolutionConfirmedBy
            && after.resolvedAt             == before.resolvedAt;
      }

      // Submit fix: only the original reporter. Flips verified → in_progress
      // and writes the "after" photo.
      function isSubmitResolution() {
        let before = resource.data;
        let after  = request.resource.data;
        return reportImmutables()
            && request.auth.uid == before.reporterId
            && before.status    == 'verified'
            && after.status     == 'in_progress'
            && after.resolvedImageUrl is string
            && after.resolvedBy == request.auth.uid
            && after.resolutionSubmittedAt is timestamp
            && after.resolutionConfirmedBy == []
            && after.resolvedAt == before.resolvedAt
            && after.verifiedBy == before.verifiedBy
            && after.flaggedBy  == before.flaggedBy
            && after.verifiedAt == before.verifiedAt;
      }

      // Confirm fix: only neighbours in the original verifiedBy may confirm,
      // and the submitter cannot confirm their own fix. At the 6-confirmer
      // threshold the status flips in_progress → resolved and resolvedAt is set.
      function isConfirmResolution() {
        let before = resource.data;
        let after  = request.resource.data;
        let nextConfirmed = before.resolutionConfirmedBy.concat([request.auth.uid]);
        let flipping = nextConfirmed.size() >= 6;
        return reportImmutables()
            && before.status == 'in_progress'
            && (request.auth.uid in before.verifiedBy)
            && request.auth.uid != before.resolvedBy
            && !(request.auth.uid in before.resolutionConfirmedBy)
            && after.resolutionConfirmedBy == nextConfirmed
            && (
                 (flipping && after.status == 'resolved' && after.resolvedAt is timestamp)
                 || (!flipping && after.status == before.status && after.resolvedAt == before.resolvedAt)
               )
            && after.verifiedBy             == before.verifiedBy
            && after.flaggedBy              == before.flaggedBy
            && after.verifiedAt             == before.verifiedAt
            && after.resolvedImageUrl       == before.resolvedImageUrl
            && after.resolvedBy             == before.resolvedBy
            && after.resolutionSubmittedAt  == before.resolutionSubmittedAt;
      }
    }

    // ─── comments (subcollection of reports) ─────────────────────────────
    // Public to read. Only real accounts can post. Updates are tightly
    // gated: (a) anyone real can append their own uid to flaggedBy, and at
    // the threshold also set hiddenAt; (b) the author can soft-delete their
    // own comment; (c) the parent report's reporter can flip helpful
    // false → true. Hard deletes are never permitted from the client.
    match /reports/{reportId}/comments/{commentId} {
      allow read: if true;

      allow create: if isRealUser()
                       && request.resource.data.commentId == commentId
                       && request.resource.data.reportId == reportId
                       && request.resource.data.authorId == request.auth.uid
                       && request.resource.data.text is string
                       && request.resource.data.text.size() > 0
                       && request.resource.data.text.size() <= 500
                       && request.resource.data.flaggedBy.size() == 0
                       && request.resource.data.helpful == false
                       && request.resource.data.hiddenAt == null
                       && request.resource.data.deletedAt == null;

      allow update: if isRealUser() && (
        isFlagUpdate() ||
        isSoftDeleteByAuthor() ||
        isHelpfulMarkByReporter()
      );

      allow delete: if false;

      // Flag: caller appends own uid, optionally sets hiddenAt at threshold.
      function isFlagUpdate() {
        let before = resource.data;
        let after  = request.resource.data;
        let nextFlags = before.flaggedBy.concat([request.auth.uid]);
        return !(request.auth.uid in before.flaggedBy)
            && after.flaggedBy == nextFlags
            && (
                 after.hiddenAt == before.hiddenAt
                 || (nextFlags.size() >= 3 && after.hiddenAt is timestamp)
               )
            && after.text       == before.text
            && after.authorId   == before.authorId
            && after.authorName == before.authorName
            && after.commentId  == before.commentId
            && after.reportId   == before.reportId
            && after.createdAt  == before.createdAt
            && after.deletedAt  == before.deletedAt
            && after.helpful    == before.helpful;
      }

      // Soft delete by author: sets deletedAt, nothing else changes.
      function isSoftDeleteByAuthor() {
        let before = resource.data;
        let after  = request.resource.data;
        return request.auth.uid == before.authorId
            && before.deletedAt == null
            && after.deletedAt is timestamp
            && after.text       == before.text
            && after.authorId   == before.authorId
            && after.authorName == before.authorName
            && after.commentId  == before.commentId
            && after.reportId   == before.reportId
            && after.createdAt  == before.createdAt
            && after.flaggedBy  == before.flaggedBy
            && after.hiddenAt   == before.hiddenAt
            && after.helpful    == before.helpful;
      }

      // Helpful mark: only the parent report's reporter, false → true,
      // on a non-hidden non-deleted comment.
      function isHelpfulMarkByReporter() {
        let parent = get(/databases/$(database)/documents/reports/$(reportId)).data;
        let before = resource.data;
        let after  = request.resource.data;
        return request.auth.uid == parent.reporterId
            && before.helpful == false
            && after.helpful  == true
            && before.deletedAt == null
            && before.hiddenAt  == null
            && after.text       == before.text
            && after.authorId   == before.authorId
            && after.authorName == before.authorName
            && after.commentId  == before.commentId
            && after.reportId   == before.reportId
            && after.createdAt  == before.createdAt
            && after.flaggedBy  == before.flaggedBy
            && after.hiddenAt   == before.hiddenAt
            && after.deletedAt  == before.deletedAt;
      }
    }

    // ─── notifications (subcollection of users) ──────────────────────────
    // In-app inbox. Any signed-in user may CREATE a notification for any
    // other user — but only as themselves (fromUid == auth.uid), and only
    // unread + properly addressed. Reads, updates (mark-read), and deletes
    // are restricted to the recipient.
    match /users/{recipientUid}/notifications/{notifId} {
      allow create: if signedIn()
                       && request.resource.data.notifId == notifId
                       && request.resource.data.recipientUid == recipientUid
                       && request.resource.data.fromUid == request.auth.uid
                       && request.resource.data.read == false
                       && request.resource.data.createdAt is timestamp;
      allow read:   if signedIn() && request.auth.uid == recipientUid;
      allow update: if signedIn() && request.auth.uid == recipientUid
                       && request.resource.data.recipientUid == resource.data.recipientUid
                       && request.resource.data.notifId == resource.data.notifId
                       && request.resource.data.fromUid == resource.data.fromUid
                       && request.resource.data.type == resource.data.type
                       && request.resource.data.reportId == resource.data.reportId
                       && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if signedIn() && request.auth.uid == recipientUid;
    }

    // ─── trivia ──────────────────────────────────────────────────────────
    // Read-only from the app. Seeded out-of-band (see scripts/seed-trivia.js).
    match /trivia/{triviaId} {
      allow read:  if true;
      allow write: if false;
    }

    // ─── deletionRequests ────────────────────────────────────────────────
    // A signed-in user may file (or overwrite) ONLY their own deletion
    // request, and only as 'pending'. They can read their own. Nothing is
    // deletable from the client — requests are cleared once processed.
    match /deletionRequests/{userId} {
      allow create, update: if signedIn()
                       && request.auth.uid == userId
                       && request.resource.data.uid == userId
                       && request.resource.data.status == 'pending';
      allow read:   if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ─── feedback ────────────────────────────────────────────────────────
    // Any signed-in user may submit feedback as themselves. Not readable,
    // updatable, or deletable from the client — reviewed in the console.
    match /feedback/{feedbackId} {
      allow create: if signedIn()
                       && request.resource.data.uid == request.auth.uid
                       && request.resource.data.message is string
                       && request.resource.data.message.size() > 0
                       && request.resource.data.message.size() <= 2000;
      allow read, update, delete: if false;
    }

    // Everything else is denied by default.
  }
}
